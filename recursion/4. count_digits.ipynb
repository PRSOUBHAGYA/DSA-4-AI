   "source": [
    "def count_digits(n):\n",
    "    ''' counting of dogots in number using recurssion '''\n",
    "    n = abs(n)\n",
    "    if n <10:\n",
    "        return 1\n",
    "    return 1+count_digits(n//10)\n"
   ]
  },
