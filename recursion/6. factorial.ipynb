   "source": [
    "def get_factorial(n):\n",
    "    if n<0:\n",
    "        return \"Infinite\"\n",
    "    if n==0:\n",
    "        return 1\n",
    "\n",
    "    return n*get_factorial(n-1)"
   ]
  },
